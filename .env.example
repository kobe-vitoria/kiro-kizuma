# ─── Jira (obrigatório) ─────────────────────────────────────────────
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER_EMAIL=service-account@your-company.com
JIRA_API_TOKEN=replace-with-jira-api-token
JIRA_PROJECT_KEY=SUPP
# JIRA_EXTRA_JQL=labels = "customer-impact"
# JIRA_CLOSED_STATUSES=["Done","Closed","Resolved"]
JIRA_PAGE_SIZE=100
JIRA_TIMEOUT_SECONDS=30

# ─── Confluence (opcional — habilita publicação) ────────────────────
CONFLUENCE_BASE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=DOC
# CONFLUENCE_PARENT_ID=123456789
CONFLUENCE_TIMEOUT_SECONDS=30

# ─── Slack (opcional — habilita notificação) ────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/PLEASE
SLACK_TIMEOUT_SECONDS=15

# ─── LLM — Google Gemini (default) ──────────────────────────────────
# Pegue sua chave em https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
LLM_API_KEY=replace-with-gemini-api-key
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=60

# Modelos Gemini disponíveis:
#   gemini-2.5-pro          — máxima qualidade, mais lento, mais caro
#   gemini-2.5-flash        — equilíbrio qualidade/custo (default)
#   gemini-2.5-flash-lite   — barato, latência mínima, alto volume
#   gemini-2.0-flash        — geração estável anterior

# ─── LLM — Anthropic Claude (alternativa) ───────────────────────────
# Para usar Anthropic em vez de Gemini, descomente abaixo e comente o bloco
# Gemini acima. A chave vai em LLM_API_KEY normalmente.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=https://api.anthropic.com/v1

# ─── Clustering ─────────────────────────────────────────────────────
CLUSTER_STRATEGY=heuristic
CLUSTER_MIN_SIZE=3
CLUSTER_TOP_N=10
CLUSTER_OVERLAP_THRESHOLD=3
CLUSTER_TEXT_MAX_LENGTH=600

# ─── GitBook RAG (opcional — habilita cache local de docs) ──────────
# URL pública da GitBook. O scraper lê /sitemap.xml a partir daqui.
GITBOOK_PUBLIC_URL=https://kobeapps.gitbook.io/kobe.io-documentacao
GITBOOK_CACHE_PATH=kiro/data/gitbook_public_cache.json
# Pausa entre requisições pra ser educado com o servidor (segundos).
GITBOOK_REQUEST_DELAY_SECONDS=0.5
# Quando true, o pipeline carrega o cache e injeta chunks relevantes
# como grounding interno no prompt do LLM. Sem cache, pipeline segue sem RAG.
ENABLE_GITBOOK_RAG=false
# Top-k chunks injetados por cluster. Acima de ~5 começa a saturar prompt.
GITBOOK_RAG_TOP_K=3
# Cosine-similarity mínimo pra um chunk entrar no contexto.
# 0.1 deixa entrar matches médios; 0.3+ exige alta similaridade.
GITBOOK_RAG_MIN_SCORE=0.1

# ─── Confluence SUP — style reference + dedupe (opcional) ──────────
# Usa artigos publicados do space SUP como few-shot pra calibrar tom +
# sinaliza quando cluster casa com artigo existente (dedupe).
CONFLUENCE_KB_SPACE_KEY=SUP
CONFLUENCE_KB_CACHE_PATH=kiro/data/confluence_sup_cache.json
CONFLUENCE_KB_REQUEST_DELAY_SECONDS=0.5
CONFLUENCE_KB_PAGE_SIZE=25
# Quando true, injeta exemplos no prompt + reporta dedupe matches.
ENABLE_CONFLUENCE_FEW_SHOT=false
# Quantos artigos similares mostrar como exemplo (1-3 é o usual).
CONFLUENCE_FEW_SHOT_TOP_K=2
# Cosine threshold pra considerar match de dedupe (0.6 = forte similaridade).
CONFLUENCE_DEDUPE_THRESHOLD=0.6

# ─── Output linter (opcional) ──────────────────────────────────────
# Roda DEPOIS do LLM e ANTES do save. BLOCK = vazamento interno (OPE-XXX,
# jargão, URLs externas) → não salva. WARN = qualidade mínima (poucos
# passos, frases genéricas) → salva mas reporta.
ENABLE_OUTPUT_LINTER=false
# skip = pula cluster bloqueado, segue rodada
# fail = derruba rodada inteira ao primeiro block
# warn = salva mesmo com block, só reporta
LINTER_BLOCK_MODE=skip

# ─── Pipeline ───────────────────────────────────────────────────────
LOOKBACK_DAYS=30
ENABLE_CONFLUENCE_PUBLISH=false
ENABLE_SLACK_NOTIFY=false
OUTPUT_DIR=output
LOG_LEVEL=INFO
DRY_RUN=false
