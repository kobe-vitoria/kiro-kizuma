# ─── Jira (obrigatório) ─────────────────────────────────────────────
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER_EMAIL=service-account@your-company.com
JIRA_API_TOKEN=replace-with-jira-api-token
JIRA_PROJECT_KEY=SUPP
# JIRA_EXTRA_JQL=labels = "customer-impact"
# JIRA_CLOSED_STATUSES=["Done","Closed","Resolved"]
JIRA_PAGE_SIZE=100
JIRA_TIMEOUT_SECONDS=30

# ─── Confluence (opcional — habilita publicação) ────────────────────
CONFLUENCE_BASE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=DOC
# CONFLUENCE_PARENT_ID=123456789
CONFLUENCE_TIMEOUT_SECONDS=30

# ─── Slack (opcional — habilita notificação) ────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/PLEASE
SLACK_TIMEOUT_SECONDS=15

# ─── LLM — Google Gemini (default) ──────────────────────────────────
# Pegue sua chave em https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
LLM_API_KEY=replace-with-gemini-api-key
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=60

# Modelos Gemini disponíveis:
#   gemini-2.5-pro          — máxima qualidade, mais lento, mais caro
#   gemini-2.5-flash        — equilíbrio qualidade/custo (default)
#   gemini-2.5-flash-lite   — barato, latência mínima, alto volume
#   gemini-2.0-flash        — geração estável anterior

# ─── LLM — Anthropic Claude (alternativa) ───────────────────────────
# Para usar Anthropic em vez de Gemini, descomente abaixo e comente o bloco
# Gemini acima. A chave vai em LLM_API_KEY normalmente.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=https://api.anthropic.com/v1

# ─── Clustering ─────────────────────────────────────────────────────
CLUSTER_STRATEGY=heuristic
CLUSTER_MIN_SIZE=3
CLUSTER_TOP_N=10
CLUSTER_OVERLAP_THRESHOLD=3
CLUSTER_TEXT_MAX_LENGTH=600

# ─── Pipeline ───────────────────────────────────────────────────────
LOOKBACK_DAYS=30
ENABLE_CONFLUENCE_PUBLISH=false
ENABLE_SLACK_NOTIFY=false
OUTPUT_DIR=output
LOG_LEVEL=INFO
DRY_RUN=false
