# App paralelo: análise de relacionamento cliente-suporte
# Copie para .env.customer_health e preencha.

# Jira
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER_EMAIL=service-account@your-company.com
JIRA_API_TOKEN=replace-with-jira-api-token
JIRA_PROJECT_KEY=SUPP
JIRA_TIMEOUT_SECONDS=30
JIRA_PAGE_SIZE=100

# LLM
LLM_PROVIDER=gemini
LLM_API_KEY=replace-with-llm-api-key
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2

# Fluxo
# Janela temporal:
# - REL_ALL_HISTORY=true  => sem limite temporal
# - REL_ALL_HISTORY=false + REL_LOOKBACK_MONTHS>0 => usa meses
# - REL_ALL_HISTORY=false + REL_LOOKBACK_DAYS>0   => usa dias
REL_ALL_HISTORY=true
REL_LOOKBACK_MONTHS=0
REL_LOOKBACK_DAYS=0
REL_TICKET_LIMIT=40
REL_OUTPUT_DIR=output/customer_relationship

# JQL customizável para buscar tickets do cliente
# Placeholders disponíveis: {project_key}, {customer_name}, {lookback_days},
# {lookback_months}, {time_clause}
REL_CUSTOMER_JQL_TEMPLATE=project = "{project_key}" AND text ~ "\"{customer_name}\"" {time_clause}ORDER BY updated DESC
